# Phase 1 — Claude motiveringsverslag
ANTHROPIC_API_KEY=

# Phase 2 — Supabase persistentie voor burger-inzendingen.
# We gebruiken de publishable / anon key in combinatie met RLS policies
# (insert + select open voor anon, geen update/delete). Toegang draait
# server-side via /api/concerns en getConcerns(); de anon key hoeft NIET
# in de client-bundle, dus geen NEXT_PUBLIC_-prefix.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_ANON_KEY=
