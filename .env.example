# Anthropic Claude — voedt plan-uitleg, chat, AI-conceptantwoorden en het verslag.
# Zonder key werkt de app op statische voorbeelddata met dezelfde structuur,
# zodat de UI lokaal verkenbaar blijft.
ANTHROPIC_API_KEY=

# Supabase — persistentie voor zienswijzen en gepubliceerde verslagen.
# We gebruiken de publishable / anon key in combinatie met RLS policies
# (insert + select open voor anon, geen update/delete). Toegang draait
# server-side via /api/concerns en getConcerns(); de anon key hoeft niet
# in de client-bundle, dus geen NEXT_PUBLIC_-prefix.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_ANON_KEY=

# Reson8 — spraak-naar-tekst (optioneel). Schakelt de microfoon-knop in
# voor de zienswijze-flow. Typen werkt altijd.
REASON8_API_KEY=
